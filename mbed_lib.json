            "help": "PDP type for the initial default bearer (CID 0). Many NB-IoT networks only support IPv4; requesting IPV4V6 causes ESM failure. Valid values: \"IP\", \"IPV6\", \"IPV4V6\".",
            "value": null
        },
        "default-pdp-context-with-apn": {
            "help": "If true, write nsapi.default-cellular-apn into AT+QCGDEFCONT so the bundled PDN Connectivity Request asks for that APN explicitly. If false (default), only the PDP type is written and the modem uses the SIM's HSS-subscribed APN. Requires default-pdp-type and nsapi.default-cellular-apn to be set.",
            "value": false
        },
        "rssi": {
